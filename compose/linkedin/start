#!/bin/bash
# compose/start

set -o errexit
set -o pipefail
set -o nounset

# Virtual display (always needed — Playwright launches headed mode)
rm -f /tmp/.X99-lock
Xvfb :99 -screen 0 1920x1080x24 &
sleep 1
export DISPLAY=:99

# VNC remote access (only for open-source local use)
if [ "${ENABLE_VNC:-false}" = "true" ]; then
    x11vnc -display :99 -forever -shared -nopw &
    websockify --web /opt/noVNC 6080 localhost:5900 &
fi

# Run Django migrations and bootstrap CRM data
python manage.py migrate --no-input
python manage.py setup_crm

# Run the daemon (forward any arguments, e.g. --onboard <file>)
exec python manage.py "$@"
